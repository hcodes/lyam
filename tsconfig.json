{
    "include": ["src/**/*"],
    "exclude": [
        "dist",
        "test",
        "manual-test",
        "node_modules",
        "rollup.config.mjs",  // Исключаем конкретный файл
        "**/*.config.mjs",    // Или все .config.mjs файлы
        "**/*.config.ts"      // Если есть конфиги в TS
    ],
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "./dist/",
        "module": "es6",
        "target": "es5",
        "declaration": true,
        "declarationDir": "./dist",
        "allowJs": true,
        "esModuleInterop": true,
        "lib": [
            "es6",
            "dom"
        ],
        "moduleResolution": "node",
        "noImplicitAny": true,
        "noImplicitThis": true,
        "strictNullChecks": false,
        "forceConsistentCasingInFileNames": true
    }
}
